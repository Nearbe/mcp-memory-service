# MCP Memory Service Local Configuration
# ========================================

# Storage Backend: sqlite_vec (local-only), cloudflare, or hybrid
MCP_MEMORY_STORAGE_BACKEND=sqlite_vec

# HTTP Interface (Web Dashboard)
MCP_HTTP_ENABLED=true
MCP_HTTP_PORT=8000
MCP_HTTP_HOST=0.0.0.0  # Listen on all network interfaces for local LAN access

# Anonymous Access for local development
MCP_ALLOW_ANONYMOUS_ACCESS=true

# Hugging Face Hub Token (optional but recommended)
# Get token from: https://huggingface.co/settings/tokens
# This enables higher rate limits and faster downloads
# HF_TOKEN=your_token_here  # Закомментируй эту строку если нет токена
